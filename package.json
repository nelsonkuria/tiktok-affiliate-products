{
  "name": "lemur-apify-starter",
  "version": "0.0.1",
  "type": "module",
  "description": "Lemur's apify actor starter template.",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@prisma/extension-accelerate": "3.0.1",
    "apify": "^3.4.2",
    "dotenv": "17.2.3",
    "pg": "8.16.3",
    "playwright-chromium": "1.57.0"
  },
  "devDependencies": {
    "@apify/eslint-config": "1.0.0",
    "@apify/tsconfig": "0.1.1",
    "@types/node": "22.19.3",
    "@types/pg": "8.16.0",
    "eslint": "9.29.0",
    "eslint-config-prettier": "^10.1.5",
    "globals": "16.2.0",
    "prettier": "3.5.3",
    "prisma": "7.8.0",
    "tsx": "4.20.3",
    "typescript": "5.8.3",
    "typescript-eslint": "8.34.1"
  },
  "scripts": {
    "start": "npm run start:dev",
    "start:prod": "node dist/src/main.js",
    "start:dev": "tsx src/main.ts",
    "build": "tsc",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "echo \"Error: oops, the Actor has no tests yet, sad!\" && exit 1"
  },
  "author": "lemurxn",
  "license": "ISC"
}
